# Example environment variables for FactLens backend
# Copy to .env and fill values before running

# Gemini API key (Gemini 2.5 Flash via @google/generative-ai)
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-preview

# Google Fact Check Tools API key
GOOGLE_FCTAPI_KEY=your_google_fct_api_key_here

# ClaimBuster API key
CLAIMBUSTER_KEY=your_claimbuster_key_here

# Upstash Redis REST credentials
UPSTASH_REDIS_REST_URL=https://eu1-upstash-your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here
